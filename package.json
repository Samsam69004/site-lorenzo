{
  "name": "app",
  "private": true,
  "scripts": {
    "build": "esbuild app/javascript/application.js --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --loader:.png=file",
    "build:css": "npx tailwindcss -i ./app/javascript/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css",
    "watch:css": "tailwindcss -i ./app/javascript/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --watch",
    "dev": "concurrently --kill-others-on-fail \"npm run watch:css\" \"npm run build -- --watch\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^7.6.0",
    "esbuild": "^0.25.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.1"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@heroicons/vue": "^2.2.0",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.13",
    "canvas-confetti": "^1.9.3",
    "js-confetti": "^0.12.0"
  },
  "packageManager": "npm@11.3.0"
}
