<section id="contact" class="text-center my-8">
  <button id="open-contact" class="bg-violetLorenzo hover:bg-purple-800 text-white font-bold py-2 px-4 rounded transition duration-300">
    Me contacter
  </button>

  <div id="contact-form" class="hidden opacity-0 translate-y-4 transition-all duration-500 max-w-xl mx-auto mt-8 bg-white bg-opacity-90 p-6 rounded-xl shadow-lg">
    <h2 class="text-2xl font-semibold text-center mb-6">Contactez-moi</h2>

    <% if @contact.errors.any? %>
      <div class="mb-6 bg-red-100 text-red-700 p-4 rounded">
        <h3 class="font-semibold mb-2">Merci de corriger les erreurs suivantes :</h3>
        <ul class="list-disc list-inside">
          <% @contact.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= render "contacts/form" %>
  </div>
</section>
