<% videos = [
  "https://www.youtube.com/embed/XVFMNwbhSAY",
  "https://www.youtube.com/embed/k-Ekc5HHuXU",
] %>


<section id="videos" class="py-20 bg-gray-100">
  <div class="max-w-2xl mx-auto px-4 text-center">
    <h2 class="text-3xl font-bold text-gray-800 mb-10">VIDEOS</h2>

    <div class="relative overflow-hidden rounded-lg">
      <div id="videoSlider"
          class="flex transition-transform duration-500 ease-in-out"
          style="transform: translateX(0%)">
        <% videos.each do |video| %>
          <div class="w-full flex-shrink-0">
            <div class="relative" style="padding-top: 56.25%;">
              <iframe
                src="<%= video %>"
                class="absolute top-0 left-0 w-full h-full rounded-xl shadow-lg"
                frameborder="0"
                allowfullscreen
              ></iframe>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Buttons -->
      <button id="prevBtn"
              class="absolute top-1/2 left-0 transform -translate-y-1/2 bg-white p-2 rounded-full shadow hover:bg-gray-200 z-10">◀</button>
      <button id="nextBtn"
              class="absolute top-1/2 right-0 transform -translate-y-1/2 bg-white p-2 rounded-full shadow hover:bg-gray-200 z-10">▶</button>
    </div>
  </div>
</section>
