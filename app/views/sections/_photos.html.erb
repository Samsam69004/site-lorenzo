<% photos = {
  "Tournages" => ["photo9.jpg", "photo2.jpg", "photo3.jpg", "photo4.jpg", "photo5.jpg", "photo6.jpg", "photo7.jpg", "photo8.jpg"],
  "Portraits"  => ["photo9.jpg","photo10.jpg", "photo11.jpg", "photo12.jpg", "photo13.jpg", "photo14.jpg", "photo15.jpg", "photo16.jpg"],
  "Scène"      => ["photo17.jpg", "photo18.jpg", "photo19.jpg", "photo20.jpg", "photo21.jpg", "photo22.jpg", "photo23.jpg", "photo24.jpg"]
} %>


<section id="photos" class="py-20 bg-gray-100">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold text-gray-800 mb-10">PHOTOS</h2>

    <!-- Onglets -->
    <div class="flex justify-center mb-6 space-x-4">
      <% photos.keys.each_with_index do |album, index| %>
        <% slug = album.parameterize %>
        <button
          class="album-tab px-4 py-2 rounded font-semibold transition-all duration-200
          <%= index == 0 ? 'bg-violetLorenzo text-white shadow' : 'bg-purple-100 text-violet-800 hover:bg-purple-200' %>"
          data-album="<%= slug %>">
          <%= album %>
        </button>

      <% end %>
    </div>

    <!-- Albums -->
    <% photos.each_with_index do |(album, photo_list), index| %>
      <% slug = album.parameterize %>
      <div class="photo-album <%= index != 0 ? 'hidden' : '' %>" data-album="<%= slug %>">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          <% photo_list.each do |photo| %>
            <div class="overflow-hidden rounded-xl shadow cursor-pointer hover:scale-105 transition"
                onclick="openLightbox('<%= asset_path("photos/#{photo}") %>')">
              <%= image_tag("photos/#{photo}", class: "w-full aspect-[3/4] object-cover object-center rounded-xl transition-transform duration-300 group-hover:scale-105") %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50 hidden">
    <div class="relative max-w-4xl w-full px-4">
      <img id="lightboxImage" src="" class="w-full rounded-xl shadow-lg max-h-[90vh] object-contain">
      <button onclick="closeLightbox()" class="absolute top-2 right-2 text-white text-3xl font-bold">&times;</button>
    </div>
  </div>
</section>
