<%= form_with model: @contact, url: contacts_path, local: true do |form| %>
  <div class="mb-4">
    <%= form.label :name, "Nom", class: "block text-gray-700" %>
    <%= form.text_field :name, class: "w-full mt-1 p-2 border rounded-md" %>
  </div>

  <div class="mb-4">
    <%= form.label :email, "Email", class: "block text-gray-700" %>
    <%= form.email_field :email, class: "w-full mt-1 p-2 border rounded-md" %>
  </div>

  <div class="mb-4">
    <%= form.label :message, "Message", class: "block text-gray-700" %>
    <%= form.text_area :message, rows: 5, class: "w-full mt-1 p-2 border rounded-md" %>
  </div>

  <div class="text-center">
    <%= form.submit "Envoyer", class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition" %>
  </div>
<% end %>
