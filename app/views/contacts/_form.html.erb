<%= form_with model: @contact, url: contacts_path, local: true do |form| %>
  <div class="mb-4">
    <%= form.label :name, "Nom", class: "block text-purple-800 font-semibold" %>
    <%= form.text_field :name, class: "w-full mt-1 p-2 border border-purple-300 rounded-md focus:ring-2 focus:ring-purple-600 transition" %>
  </div>

  <div class="mb-4">
    <%= form.label :email, "Email", class: "block text-purple-800 font-semibold" %>
    <%= form.email_field :email, class: "w-full mt-1 p-2 border border-purple-300 rounded-md focus:ring-2 focus:ring-purple-600 transition" %>
  </div>

  <div class="mb-6">
    <%= form.label :message, "Message", class: "block text-purple-800 font-semibold" %>
    <%= form.text_area :message, rows: 5, class: "w-full mt-1 p-2 border border-purple-300 rounded-md focus:ring-2 focus:ring-purple-600 transition" %>
  </div>

  <div class="text-center">
    <%= form.submit "Envoyer", class: "bg-purple-700 text-white px-6 py-2 rounded-lg hover:bg-purple-800 active:scale-95 transition-all duration-300 shadow-md" %>
  </div>
<% end %>
