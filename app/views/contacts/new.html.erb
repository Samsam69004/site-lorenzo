<section id="contact" class="text-center my-8">
  <button id="open-contact" class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700 transition">
    Me contacter
  </button>

  <div id="contact-form" class="hidden opacity-0 translate-y-4 transition-all duration-500 max-w-xl mx-auto mt-8 bg-white bg-opacity-95 p-8 rounded-xl shadow-2xl">
    <h2 class="text-2xl font-semibold text-center mb-6 text-gray-800">Contactez-moi</h2>

    <% if @contact.errors.any? %>
      <div class="mb-6 bg-red-100 text-red-700 p-4 rounded">
        <h3 class="font-semibold mb-2">Merci de corriger les erreurs suivantes :</h3>
        <ul class="list-disc list-inside text-sm">
          <% @contact.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= render "contacts/form" %>
  </div>
</section>
