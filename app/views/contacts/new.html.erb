<div class="min-h-screen flex items-center justify-center bg-gray-100 py-12 px-4">
  <div class="bg-white bg-opacity-90 p-8 rounded-xl shadow-lg w-full max-w-lg">
    <h2 class="text-2xl font-semibold text-center mb-6">Contacte-moi</h2>

    <% if @contact.errors.any? %>
      <div class="mb-6 bg-red-100 text-red-700 p-4 rounded">
        <h3 class="font-semibold mb-2">Merci de corriger les erreurs suivantes :</h3>
        <ul class="list-disc list-inside">
          <% @contact.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @contact, url: contacts_path, local: true do |form| %>
      <div class="mb-4">
        <%= form.label :name, "Nom", class: "block text-gray-700" %>
        <%= form.text_field :name, class: "w-full mt-1 p-2 border rounded-md" %>
      </div>

      <div class="mb-4">
        <%= form.label :email, "Email", class: "block text-gray-700" %>
        <%= form.email_field :email, class: "w-full mt-1 p-2 border rounded-md" %>
      </div>

      <div class="mb-4">
        <%= form.label :message, "Message", class: "block text-gray-700" %>
        <%= form.text_area :message, rows: 5, class: "w-full mt-1 p-2 border rounded-md" %>
      </div>

      <div class="text-center">
        <%= form.submit "Envoyer", class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition" %>
      </div>
    <% end %>
  </div>
</div>
